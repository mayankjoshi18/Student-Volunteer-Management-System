PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/student_volunteer
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
NODE_ENV=development

# Email Configurations (Nodemailer SMTP Settings)
# E.g. for Ethereal Mail testing, standard SMTP, or Gmail
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=your_smtp_username_here
EMAIL_PASS=your_smtp_password_here

# Base URL
BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
